@misc{RiastradNote,
  key = {\textit{R\'iastrad}},
  note = {The English rendering of the \textit{r\'{i}astrad} provided here is a composite translation. We adopt the verb \textit{squeezed} and the clausal structure from \cite{kinsella1969tain}, the comparative \textit{no wider} and the specific \textit{mead-cup} (\textit{midch\'{u}aich}) terminology from \cite{windischdunn1914tain}, and refer to the 12th-century primary source \cite{lebornahuidre} for the original Old Irish: ``\'{I}adais indala s\'{u}il conn\'{a}rbo lethiu indaas cr\'{o} sn\'{a}thaite. As\'{o}ilgg alaili co mbo m\'{o}ir b\'{e}olu midch\'{u}aich.''}
}

